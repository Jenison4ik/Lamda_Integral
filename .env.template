PORT=5000
NODE_ENV=development
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Имя бота для Telegram Login Widget (страница входа в нативном приложении), без @. Должно совпадать с @username бота в Telegram (например lambda_integral_bot).
TELEGRAM_BOT_USERNAME=lambda_integral_bot

# Публичный URL API (для редиректа после входа через Telegram). На Vercel можно не задавать — подставится VERCEL_URL
# PUBLIC_API_URL=https://your-app.vercel.app

# JWT для пользователей приложения (нативный вход, Mini App). Обязателен для /api/auth/telegram-login и /api/auth/webapp
APP_JWT_SECRET=change_me_app_jwt

DATABASE_URL="url_to_your_turso_database"
TURSO_AUTH_TOKEN="your_turso_auth_token"

# Локальная SQLite для prisma migrate (обязательно при миграциях). См. docs/TURSO_MIGRATIONS.md
LOCAL_DATABASE_URL="file:./prisma/dev.db"

# Админ-панель (сервер)
ADMIN_PASSWORD="change_me"
ADMIN_JWT_SECRET="change_me_too"
